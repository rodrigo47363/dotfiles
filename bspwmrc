#! /bin/sh

# ==========================================
# 1. ENTORNO Y FIXES COMPATIBILIDAD
# ==========================================
wmname LG3D &
vmware-user-suid-wrapper &
xsetroot -cursor_name left_ptr &

# ==========================================
# 2. ESPACIOS DE TRABAJO Y REGLAS (BSPWM)
# ==========================================
bspc monitor -d I II III IV V VI VII VIII IX X

bspc config border_width         2  # Decide aquí tu grosor (elimina el 0 del final)
bspc config window_gap          12

bspc config split_ratio          0.52
bspc config borderless_monocle   true
bspc config gapless_monocle      true
bspc config focus_follows_pointer true

bspc rule -a Gimp desktop='^8' state=floating follow=on
bspc rule -a Chromium desktop='^2'
bspc rule -a mplayer2 state=floating
bspc rule -a Kupfer.py focus=on
bspc rule -a Screenkey manage=off

# ==========================================
# 3. DAEMONS Y AUTOARRANQUE (Con protección)
# ==========================================

# Matamos instancias previas para evitar duplicados al recargar bspwm
pkill -x sxhkd
pkill -x picom
pkill -x lxpolkit

# Lanzamos los procesos limpios
sxhkd &
picom &
lxpolkit &

# ==========================================
# 4. HARDWARE E INTERFAZ
# ==========================================

# Habilitar Tapping en Touchpad
xinput set-prop "ELAN050A:01 04F3:3158 Touchpad" "libinput Tapping Enabled" 1 &

# Resolucion Arandr (Tu script de monitores iría aquí)

# Wallpaper y Barra
feh --bg-fill ~/Wallpaper/s4vitar.png
~/.config/polybar/launch.sh
