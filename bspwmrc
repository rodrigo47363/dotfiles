#! /bin/sh

# ==========================================
# 1. ENTORNO Y FIXES
# ==========================================
# Cambiamos wmname para compatibilidad con aplicaciones Java (ej: BurpSuite)
wmname LG3D &
xsetroot -cursor_name left_ptr &

# ==========================================
# 2. CONFIGURACIÓN BSPWM
# ==========================================
bspc monitor -d I II III IV V VI VII VIII IX X

bspc config border_width        2  
bspc config window_gap         12
bspc config split_ratio         0.52
bspc config borderless_monocle  true
bspc config gapless_monocle     true
bspc config focus_follows_pointer true
bspc config normal_border_color "#4c566a"
bspc config active_border_color "#88c0d0"
bspc config focused_border_color "#81a1c1"

# Reglas de Pentesting: Fuerza herramientas a escritorios específicos y estados
bspc rule -a BurpSuite desktop='^10' state=tiled follow=on
bspc rule -a Firefox desktop='^2'
bspc rule -a Gimp state=floating follow=on
bspc rule -a mpv state=floating
bspc rule -a Screenkey manage=off

# ==========================================
# 3. AUTOARRANQUE (Limpieza total)
# ==========================================
# Usamos un bucle para matar procesos solo si existen, evitando errores
for proc in sxhkd picom lxpolkit; do
    pkill -x "$proc"
done

sxhkd &
picom --config ~/.config/picom/picom.conf &
lxpolkit &

# ==========================================
# 4. HARDWARE E INTERFAZ
# ==========================================
# Tapping persistente (mejor con variable)
TOUCHPAD_ID=$(xinput list --name-only | grep -i "touchpad")
if [ -n "$TOUCHPAD_ID" ]; then
    xinput set-prop "$TOUCHPAD_ID" "libinput Tapping Enabled" 1
fi

# Wallpaper y Barra
[ -f ~/Wallpaper/rodrigo47363.png ] && feh --bg-fill ~/Wallpaper/rodrigo47363.png &
$HOME/.config/polybar/launch.sh &
